{
  "name": "@bike4mind/client",
  "version": "0.1.61",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/copy-tavern-assets.mjs && node scripts/copy-pdf-worker.mjs && node scripts/generate-premium-glue.mjs",
    "codegen": "node scripts/generate-premium-glue.mjs",
    "predev": "node scripts/copy-pdf-worker.mjs && node scripts/generate-premium-glue.mjs",
    "prebuild": "node scripts/copy-pdf-worker.mjs",
    "dev": "WATCHPACK_POLLING=true next dev",
    "devPerformance": "sst ${SST_ARGS} bind \"bash -c 'NEXT_PUBLIC_VERBOSE_PERFORMANCE=true NODE_OPTIONS=--inspect node_modules/.bin/next dev'\"",
    "devTTFVT": "sst ${SST_ARGS} bind \"bash -c 'NEXT_PUBLIC_VERBOSE_PERFORMANCE=true BYPASS_QUEUE=true ENABLE_SERVER_THROTTLING=false NODE_OPTIONS=--inspect node_modules/.bin/next dev'\"",
    "local:frontend": "NEXT_PUBLIC_VERBOSE_PERFORMANCE=false next dev",
    "local:frontend:perf": "NEXT_PUBLIC_VERBOSE_PERFORMANCE=true next dev",
    "local:frontend:ttfvt": "NEXT_PUBLIC_VERBOSE_PERFORMANCE=true BYPASS_QUEUE=true ENABLE_SERVER_THROTTLING=false next dev",
    "local:backend": "npm --prefix server run dev",
    "local": "concurrently npm:local:*",
    "sst": "sst",
    "build": "NODE_OPTIONS='--max-old-space-size=12288' next build",
    "clean": "rm -rf node_modules/ .next/ .sst/ public/pdfjs public/pdf.worker.min.mjs",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write './**/*.{ts,tsx}'",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "typecheck:fast": "tsgo --noEmit || NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "vitest run",
    "test:e2e:setup": "node scripts/setup-e2e.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "depcheck": "depcheck",
    "analyze": "TURBOPACK_STATS=1 next build",
    "decision-maker:convert": "tsx server/scripts/decisionMakerCsvProcessor.ts",
    "db:create-user": "tsx server/scripts/createUser.ts",
    "db:seed-users": "tsx server/seed/seedUser.ts",
    "security:scan": "semgrep scan --config auto --exclude node_modules --exclude .next --exclude .sst",
    "help:build-index": "tsx ../../packages/scripts/help/build-help-index.ts",
    "help:bundle-content": "tsx ../../packages/scripts/help/bundle-help-content.ts",
    "help:build": "pnpm help:build-index && pnpm help:bundle-content"
  },
