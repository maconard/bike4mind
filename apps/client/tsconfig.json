{
  "extends": "@bike4mind/typescript-config/next.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "@pages/*": ["./pages/*"],
      "@public/*": ["./public/*"],
      "@server/*": ["./server/*"],
      "@selfhost/quest-runner": ["./server/utils/selfhostQuestRunner"],
      "@client/*": ["./*"],
      "@/*": ["./*"]
    }
  },
  "exclude": [
    "node_modules",
    "public/sw.js",
    "app/sw.ts",
    "e2e",
    "playwright.config.ts",
    "ios",
    "android",
    "**/*.test.ts",
    "**/*.test.tsx",
    ".next/standalone",
    ".next/server",
    ".next/cache",
    ".next/static",
    ".open-next"
  ],
  "include": [
    "next-env.d.ts",
    "global.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../scripts/migrate/migrations/manageDatabase.ts",
    ".next/types/**/*.ts"
  ]
}
