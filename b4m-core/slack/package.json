{
  "name": "@bike4mind/slack",
  "version": "0.0.1",
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Bike4Mind/bike4mind.git",
    "directory": "b4m-core/slack"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsdown",
    "incremental": "tsdown",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit --types node",
    "typecheck:fast": "tsgo --noEmit --types node || tsc --noEmit",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@bike4mind/agents": "workspace:*",
    "@bike4mind/common": "workspace:*",
    "@bike4mind/fab-pipeline": "workspace:*",
    "@bike4mind/llm-adapters": "workspace:*",
    "@bike4mind/mcp": "workspace:*",
    "@bike4mind/observability": "workspace:*",
    "@bike4mind/services": "workspace:*",
    "@bike4mind/utils": "workspace:*",
    "@slack/oauth": "^3.0.5",
    "@slack/web-api": "^7.16.0",
    "axios": "1.16.1",
    "cheerio": "1.2.0",
    "chrono-node": "^2.9.1",
    "dayjs": "^1.11.20",
    "mongoose": "^8.24.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/mdast": "^4.0.4",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
